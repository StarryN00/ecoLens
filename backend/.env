# 数据库配置 - 本地开发使用 SQLite（无需安装 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./nestdb.sqlite

# Redis配置 - 本地开发模式（如果不启动 Redis，Celery 会降级为同步处理）
REDIS_URL=redis://localhost:6379/0

# Celery配置 - 使用 SQLite 作为 broker（本地开发模式）
CELERY_BROKER_URL=sqla+sqlite:///celerydb.sqlite
CELERY_RESULT_BACKEND=db+sqlite:///celerydb.sqlite

# 文件存储
UPLOAD_DIR=./uploads
THUMBNAIL_DIR=./thumbnails

# AI模型路径
# 旧模型: ./models/best.pt
# 新模型: ./models/nest_detector_6b95fc41-2f15-40fc-978a-42e81bd369bb.pt
TREE_MODEL_PATH=./models/nest_detector_6b95fc41-2f15-40fc-978a-42e81bd369bb.pt
NEST_MODEL_PATH=./models/nest_detector_6b95fc41-2f15-40fc-978a-42e81bd369bb.pt
NEST_DETECTION_MODEL_PATH=./models/nest_detector_6b95fc41-2f15-40fc-978a-42e81bd369bb.pt
TREE_CLASSIFICATION_MODEL_PATH=./models/nest_detector_6b95fc41-2f15-40fc-978a-42e81bd369bb.pt

# 虫巢检测置信度阈值 (0.0-1.0)，降低以捕获更多潜在目标
CONFIDENCE_THRESHOLD=0.005

# 应用配置
DEBUG=True
APP_NAME=樟巢螟智能检测系统
